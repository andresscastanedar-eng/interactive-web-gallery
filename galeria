<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galería Proyecto de Biología</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        :root {
            --verde-principal: #4f6b45;
            --verde-secundario: #738a5e;
            --beige: #efe3c2;
            --beige-claro: #f7f1df;
            --terracota: #b66a4d;
            --marron: #6d5b45;
            --overlay-gradient: linear-gradient(
                to top,
                rgba(30, 24, 16, 0.88) 0%,
                rgba(30, 24, 16, 0.55) 45%,
                rgba(30, 24, 16, 0.0) 100%
            );
        }

        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: 'Jost', sans-serif;
            background:
                radial-gradient(circle at 15% 25%, rgba(79,107,69,.07) 0%, transparent 40%),
                radial-gradient(circle at 85% 70%, rgba(182,106,77,.06) 0%, transparent 35%),
                var(--beige-claro);
            color: var(--marron);
        }

        .page-header {
            padding: 3.5rem 0 2rem;
            text-align: center;
        }

        .page-header .eyebrow {
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            font-size: .72rem;
            letter-spacing: .35em;
            text-transform: uppercase;
            color: var(--verde-secundario);
            margin-bottom: .6rem;
        }

        .page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 300;
            font-size: clamp(2.4rem, 5vw, 3.8rem);
            line-height: 1.1;
            color: var(--verde-principal);
            margin-bottom: 0;
        }

        .page-header h1 em {
            font-style: italic;
            color: var(--terracota);
        }

        .divider {
            width: 48px;
            height: 1px;
            background: var(--terracota);
            margin: 1.4rem auto 0;
            opacity: .5;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: auto auto;
            gap: 12px;
            padding: 0 0 12px;
        }

        .gallery-grid .media-item:first-child {
            grid-row: span 1;
        }

        .media-item {
            position: relative;
            overflow: hidden;
            border-radius: 6px;
            cursor: default;
            background-color: #d8cdb5; 
        }
        .media-item .ratio-box {
            position: relative;
            width: 100%;
            padding-top: 70%;         
        }
        .media-item.video-item .ratio-box {
            padding-top: 56.25%;   
        }

        .media-item img,
        .media-item video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .55s cubic-bezier(.25,.46,.45,.94);
        }

        .media-item .placeholder-icon {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: rgba(109,91,69,.28);
            font-family: 'Cormorant Garamond', serif;
            font-size: .78rem;
            letter-spacing: .12em;
            text-transform: uppercase;
            gap: .5rem;
            pointer-events: none;
            transition: opacity .3s;
        }

        .media-item .placeholder-icon svg {
            width: 36px;
            height: 36px;
            opacity: .45;
        }

        .media-item img[src]:not([src=""]) ~ .placeholder-icon,
        .media-item video[src]:not([src=""]) ~ .placeholder-icon {
            opacity: 0;
        }

        .hover-overlay {
            position: absolute;
            inset: 0;
            background: var(--overlay-gradient);
            opacity: 0;
            transition: opacity .4s ease;
            pointer-events: none;
            border-radius: inherit;
        }

        .hover-text {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 1.4rem 1.2rem 1.1rem;
            transform: translateY(8px);
            opacity: 0;
            transition: opacity .4s ease, transform .4s ease;
            pointer-events: none;
            z-index: 2;
        }

        .hover-text .label {
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            font-size: .6rem;
            letter-spacing: .28em;
            text-transform: uppercase;
            color: rgba(255,255,255,.55);
            margin-bottom: .3rem;
            z-index: 2;
            z-index: 2;
        }

        .hover-text h3 {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 400;
            font-size: 1.15rem;
            color: #fff;
            margin-bottom: .35rem;
            line-height: 1.25;
            z-index: 2;
        }

        .hover-text p {
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            font-size: .72rem;
            color: rgba(255,255,255,.72);
            line-height: 1.55;
            margin: 0;
            z-index: 2;
        }

        .media-item:hover .hover-overlay { opacity: 1; }
        .media-item:hover .hover-text    { opacity: 1; transform: translateY(0); }
        .media-item:hover img,
        .media-item:hover video          { transform: scale(1.04); }

        .section-label {
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            font-size: .68rem;
            letter-spacing: .3em;
            text-transform: uppercase;
            color: var(--verde-secundario);
            text-align: center;
            padding: 2rem 0 .8rem;
        }

        .page-footer {
            text-align: center;
            padding: 2.5rem 0 2rem;
            font-family: 'Jost', sans-serif;
            font-size: .72rem;
            font-weight: 300;
            letter-spacing: .08em;
            color: rgba(109,91,69,.5);
        }

        @media (max-width: 576px) {
            .gallery-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

<div class="container" style="max-width: 860px;">

