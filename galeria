        </div>

    </div>
    <!-- Footer -->
    <footer class="page-footer">
        © 2026 Andrés Castañeda &nbsp;·&nbsp; Fermentación
    </footer>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
