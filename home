<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fermentación - Andrés Castañeda</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        :root{
            --verde-principal:#4f6b45;
            --verde-secundario:#738a5e;
            --beige:#efe3c2;
            --beige-claro:#f7f1df;
            --terracota:#b66a4d;
            --marron:#6d5b45;
        }

        body{
            min-height:100vh;
            font-family: Georgia, serif;
            background:
                radial-gradient(circle at 20% 20%, rgba(255,255,255,.2) 0%, transparent 30%),
                radial-gradient(circle at 80% 60%, rgba(255,255,255,.15) 0%, transparent 25%),
                linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px),
                var(--beige);
            background-size: auto, auto, 8px 8px, 8px 8px, auto;
            color: var(--marron);
        }

        .main-card{
            background: rgba(247,241,223,.92);
            border: 2px solid rgba(109,91,69,.15);
            border-radius: 20px;
            overflow: hidden;
            backdrop-filter: blur(4px);
            box-shadow:
                0 15px 40px rgba(0,0,0,.12),
                0 0 0 1px rgba(255,255,255,.5);
        }

        .card-header{
            background: linear-gradient(
                135deg,
                var(--verde-principal),
                var(--verde-secundario)
            ) !important;
            border-bottom: 4px solid rgba(255,255,255,.15);
            padding: 1.5rem;
        }

        .card-header h1{
            font-weight: bold;
            letter-spacing: 1px;
        }

        .card-body h2{
            color: var(--verde-principal);
            font-weight: bold;
        }

        .form-label{
            color: var(--marron);
            font-weight: 600;
        }

        .form-control, .form-select{
            border: 1px solid #d7c9a7;
            background-color: rgba(255,255,255,.65);
            border-radius: 10px;
            padding: 0.75rem;
            transition: .3s;
        }

        .form-control:focus, .form-select:focus{
            border-color: var(--verde-secundario);
            box-shadow: 0 0 0 .25rem rgba(115,138,94,.2);
        }

        .btn-vintage{
            background-color: var(--terracota);
            border: none;
            color: white;
            font-weight: bold;
            letter-spacing: .5px;
            border-radius: 12px;
            transition: .3s;
        }

        .btn-vintage:hover{
            background-color: #9d573d;
            transform: translateY(-2px);
        }

        .card-footer{
            background-color: rgba(79,107,69,.08);
            color: var(--marron);
        }

        .botanical-detail{
            text-align:center;
            color:var(--verde-secundario);
            font-size:1.2rem;
            margin-bottom:1rem;
        }

    </style>
</head>

<body>

    <div class="container-fluid py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">

                <div class="card main-card">

                    <div class="card-header text-white text-center">
                        <h1 class="h3 mb-0">
                            🌿 Fermentación
                        </h1>
                    </div>

                    <div class="card-body p-4">

                        <div class="botanical-detail">
                            ✦ Estudio Biológico ✦
                        </div>

                        <h2 class="text-center mb-3">
                            Formulario de Registro
                        </h2>

                        <p class="text-center text-muted mb-4">
                            Ingrese sus datos para continuar
                        </p>

                        <form id="formulario">

                            <div class="mb-3">
                                <label for="nombre" class="form-label">
                                    Nombre
                                </label>
                                <input
                                    type="text"
                                    class="form-control"
                                    id="nombre"
                                    placeholder="Ingrese su nombre"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label for="edad" class="form-label">
                                    Edad
                                </label>
                                <input
                                    type="number"
                                    class="form-control"
                                    id="edad"
                                    placeholder="Ingrese su edad"
                                    required>
                            </div>

                            <div class="mb-4">
                                <label for="grado" class="form-label">
                                    Nivel
                                </label>
                                <select class="form-select" id="grado" required>
                                    <option value="" disabled selected>Seleccione su nivel</option>
                                        <option value="Primaria">Bachillerato</option>
                                        <option value="Universitario">Universitario</option>
                                        <option value="Trabajador">Trabajador</option>             
                                </select>
                            </div>

                            <div class="d-grid">
                                <button
                                    class="btn btn-vintage btn-lg"
                                    type="submit">
                                    Continuar
                                </button>
                            </div>

                        </form>

                   <script>
document.getElementById("formulario").addEventListener("submit", function(e) {
    e.preventDefault();

    window.open(
        "https://sites.google.com/view/examenfinalprogra/galer%C3%ADa",
        "_blank"
    );
});
</script>

                    </div>

                    <div class="card-footer text-center">
                        © 2026 Andrés Castañeda
                    </div>

                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
